{
  "name": "@asamuzakjp/css-color",
  "description": "CSS color - Resolve and convert CSS colors.",
  "author": "asamuzaK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asamuzaK/cssColor.git"
  },
  "homepage": "https://github.com/asamuzaK/cssColor#readme",
  "bugs": {
    "url": "https://github.com/asamuzaK/cssColor/issues"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "default": "./dist/esm/index.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@asamuzakjp/generational-cache": "^2.0.1",
    "@csstools/css-calc": "^3.2.0",
    "@csstools/css-color-parser": "^4.1.0",
    "@csstools/css-parser-algorithms": "^4.0.0",
    "@csstools/css-tokenizer": "^4.0.0"
  },
  "devDependencies": {
    "@tanstack/vite-config": "^0.5.2",
    "@types/node": "^25.6.2",
    "@vitest/coverage-istanbul": "^4.1.5",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-regexp": "^3.1.0",
    "globals": "^17.6.0",
    "knip": "^6.12.2",
    "mitata": "^1.0.34",
    "neostandard": "^0.13.0",
    "prettier": "^3.8.3",
    "publint": "^0.3.20",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@microsoft/api-extractor": {
      "minimatch": "^3.1.3"
    },
    "ajv": "^ 8.18.0",
    "lodash": "^4.18.0"
  },
  "scripts": {
    "bench:color": "npx tsx --expose-gc ./benchmark/bench-color.ts",
    "build": "npm run clean && npm run test && npm run knip && vite build && npm run publint",
    "clean": "rimraf ./coverage ./dist",
    "knip": "knip",
    "prettier": "prettier . --ignore-unknown --write",
    "publint": "publint --strict",
    "test": "npm run prettier && npm run --stream \"/^test:.*/\"",
    "test:eslint": "eslint ./src ./test --fix",
    "test:types": "tsc",
    "test:unit": "vitest"
  },
  "engines": {
    "node": "^22.13.0 || >=24.0.0"
  },
  "version": "6.0.1"
}
